{
  "name": "rkwsk-next",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=24.17.0 <25",
    "npm": ">=11.13.0 <12"
  },
  "scripts": {
    "dev": "concurrently -n next,storybook -c blue,magenta \"npm run dev:next\" \"npm run storybook\"",
    "dev:next": "next dev",
    "build": "npm run test-silent && next build",
    "start": "next start",
    "fix": "npm run lint:fix && npm run test-silent",
    "lint": "npm run lint:js && npm run lint:css && npm run test",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:css": "stylelint **/*.{css,scss,sass}",
    "lint:css:fix": "stylelint --fix **/*.{css,scss,sass}",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "jest",
    "test-silent": "jest --silent"
  },
  "dependencies": {
